<Window
    x:Class="TextCleaner.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Text Cleaner">

    <Window.SystemBackdrop>
        <MicaBackdrop/>
    </Window.SystemBackdrop>

    <Grid Margin="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Row 0: Toolbar (Paste / Copy) -->
        <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="PasteBtn"
                    Grid.Column="0"
                    Content="Paste from Clipboard"
                    HorizontalAlignment="Stretch"
                    Margin="0,0,6,0"
                    Height="40"
                    CornerRadius="8"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="#4F46E5"
                    Foreground="White"
                    Click="PasteBtn_Click"/>

            <Button x:Name="CopyBtn"
                    Grid.Column="1"
                    Content="Copy to Clipboard"
                    HorizontalAlignment="Stretch"
                    Margin="6,0,0,0"
                    Height="40"
                    CornerRadius="8"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="#059669"
                    Foreground="White"
                    Click="CopyBtn_Click"/>
        </Grid>

        <!-- Row 1: Input / Output text boxes -->
        <TextBox x:Name="InputBox"
                 Grid.Row="1" Grid.Column="0"
                 AcceptsReturn="True"
                 IsSpellCheckEnabled="False"
                 FontFamily="Consolas"
                 FontSize="13"
                 TextWrapping="NoWrap"
                 CornerRadius="8"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 Margin="0,0,6,0"
                 TextChanged="InputBox_TextChanged"
                 PlaceholderText="Paste or type input text here…"/>

        <TextBox x:Name="OutputBox"
                 Grid.Row="1" Grid.Column="1"
                 AcceptsReturn="True"
                 IsSpellCheckEnabled="False"
                 FontFamily="Consolas"
                 FontSize="13"
                 TextWrapping="NoWrap"
                 CornerRadius="8"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 Margin="6,0,0,0"
                 PlaceholderText="Cleaned output appears here…"/>

        <!-- Row 2: Theme toggle (left) | Clear (center) | Settings (right) -->
        <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Theme toggle - bottom LEFT -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <ToggleSwitch x:Name="ThemeToggle"
                              OnContent="Dark"
                              OffContent="Light"
                              VerticalAlignment="Center"
                              Toggled="ThemeToggle_Toggled"/>
                <TextBlock x:Name="RulesStatusText"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Opacity="0.8"
                           Margin="-8,0,0,0"/>
            </StackPanel>

            <!-- Clear - truly centered by spanning all columns -->
            <Button x:Name="ClearBtn"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Content="Clear Text"
                    HorizontalAlignment="Center"
                    Width="160"
                    Height="36"
                    CornerRadius="8"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="#DC2626"
                    Foreground="White"
                    Click="ClearBtn_Click"/>

            <!-- Settings - bottom RIGHT -->
            <Button x:Name="SettingsBtn"
                    Grid.Column="2"
                    Content="⚙ Settings"
                    VerticalAlignment="Center"
                    Height="36"
                    CornerRadius="8"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="#7C3AED"
                    Foreground="White"
                    Click="SettingsBtn_Click"/>
        </Grid>
    </Grid>
</Window>
